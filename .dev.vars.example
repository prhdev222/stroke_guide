# .dev.vars — สำหรับทดสอบ local ด้วย wrangler pages dev
# copy ไฟล์นี้ → .dev.vars แล้วใส่ค่าจริง
# ไฟล์ .dev.vars อยู่ใน .gitignore แล้ว — ไม่ขึ้น GitHub

# ── Turso Database (จาก app.turso.tech) ─────────────────
TURSO_URL=https://stroke-db-xxxxxx.turso.io
TURSO_TOKEN=eyJhbGci...

# ── AI Keys (ใส่อย่างน้อย 1) ────────────────────────────
GROQ_API_KEY=gsk_...
SAMBANOVA_API_KEY=sn-...

# ── Email via Resend (optional — ส่ง PDF ให้ Admin) ─────
# Free plan: ส่งได้เฉพาะอีเมลที่ใช้สมัคร Resend — ใช้เมลทีม stroke แล้วตั้ง ADMIN_EMAIL ให้ตรงกัน
RESEND_API_KEY=re_xxxxxxxxxx
ADMIN_EMAIL=stroketeamprh@gmail.com
# NEURO_EMAIL=...  (ไม่บังคับ — ถ้าไม่มี ADMIN_EMAIL ระบบจะลองใช้ค่านี้)

# ── CT ชั่วคราวให้ Neuro (optional — ต้องผูก KV CT_SESSIONS + R2 CT_IMAGES ใน Pages)
# CT_TEMP_SECRET=รหัสลับ  (ถ้าตั้ง ต้องใส่ในช่อง Staff wizard ตอนสร้างลิงก์)
#
# ── LINE (optional) ──────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
WEBAPP_URL=http://localhost:8788
LINE_NEURO_USER_ID=
LINE_REFER_USER_ID=
